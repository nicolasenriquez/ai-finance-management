{
  "name": "ai-finance-management-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run type-check && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit --pretty false -p tsconfig.app.json && tsc --noEmit --pretty false -p tsconfig.node.json",
    "type-check": "tsc --noEmit --pretty false -p tsconfig.app.json && tsc --noEmit --pretty false -p tsconfig.node.json",
    "test": "vitest run",
    "cwv:measure": "node scripts/measure-cwv.mjs",
    "frontend:evidence": "node scripts/capture-frontend-evidence.mjs"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.66.0",
    "decimal.js": "^10.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.2.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.4.1",
    "jsdom": "^26.0.0",
    "playwright": "^1.50.1",
    "typescript": "^5.7.3",
    "vite": "^6.1.0",
    "vitest": "^4.1.2"
  }
}
