# =============================================================================
# Application Configuration
# =============================================================================

# Application metadata
APP_NAME=AI Finance Management
VERSION=0.1.0
ENVIRONMENT=development
LOG_LEVEL=INFO
API_PREFIX=/api

# CORS - allowed origins for cross-origin requests
# Must be a JSON array format (with double quotes)
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:8123"]

# PDF preflight heuristic
PDF_PREFLIGHT_MIN_TEXT_CHARS=20

# PDF ingestion
PDF_UPLOAD_STORAGE_ROOT=.data/pdf_uploads
PDF_UPLOAD_MAX_BYTES=10485760
PDF_UPLOAD_MAX_PAGES=50

# =============================================================================
# Database Configuration
# =============================================================================
# Docker local baseline supports:
# - legacy-compatible defaults for existing local docker volumes
# - optional dedicated runtime app role by overriding POSTGRES_APP_* values
#
# For stronger local posture, set non-default values after copying `.env.example` to `.env`.
POSTGRES_ADMIN_PASSWORD=postgres
POSTGRES_APP_USER=postgres
POSTGRES_APP_PASSWORD=postgres
POSTGRES_APP_DB=ai_finance_management

# Works with ANY PostgreSQL provider - just change the connection string

# Docker (default - use with docker-compose up)
# Note: Using port 5433 to avoid conflicts with local PostgreSQL on standard port 5432
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/ai_finance_management

# Supabase Cloud
# DATABASE_URL=postgresql+asyncpg://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Supabase Local (default configuration)
# Start with: supabase start
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:54322/postgres

# Neon (Serverless Postgres)
# DATABASE_URL=postgresql+asyncpg://[user]:[password]@[endpoint].neon.tech/[dbname]?sslmode=require

# Railway
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@[host].railway.app:[port]/railway

# Local PostgreSQL (non-Docker, standard port)
# If you have PostgreSQL installed locally on the standard port:
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@localhost:5432/ai_finance_management

# Local PostgreSQL (non-Docker, custom port)
# If you installed PostgreSQL on a custom port to avoid conflicts:
# DATABASE_URL=postgresql+asyncpg://postgres:[password]@localhost:5433/ai_finance_management
